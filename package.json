{
  "name": "@extrachill/chat",
  "version": "0.2.1",
  "description": "Chat UI components with built-in REST API client. Speaks the standard chat message format natively.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./css": "./css/chat.css",
    "./src": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./src/*": {
      "types": "./src/*.tsx",
      "default": "./src/*.tsx"
    }
  },
  "files": [
    "src",
    "dist",
    "css",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "chat",
    "react",
    "wordpress",
    "gutenberg",
    "ai",
    "components"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Extra-Chill/chat.git"
  },
  "homepage": "https://github.com/Extra-Chill/chat",
  "bugs": "https://github.com/Extra-Chill/chat/issues",
  "license": "GPL-2.0-or-later",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  }
}
